---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionDivider from '../components/SectionDivider.astro';
import ContactForm from '../components/ContactForm.astro';

const presencialPlans = [
  {
    name: 'Básico',
    price: '112€',
    period: '/Mês',
    popular: false,
    features: [
      '4 aulas de 1h/mês',
      'Horário fixo',
      'Aulas individuais',
      'Concertos & Jam Sessions',
      'Comunidade',
    ],
  },
  {
    name: 'Músico',
    price: '140€',
    period: '/Mês',
    popular: true,
    features: [
      '8 aulas de 1h/mês',
      'Horário fixo',
      'Aulas individuais + Cadeira Complementar',
      'Concertos & Jam Sessions',
      'Comunidade',
    ],
  },
  {
    name: 'Pack',
    price: '130€',
    period: '/4 Aulas',
    popular: false,
    features: [
      'Aula individual',
      'Agenda quando quiseres',
      'Concertos & Jam Sessions',
      'Comunidade',
    ],
  },
];

const onlinePlans = [
  {
    name: 'Básico',
    price: '115€',
    period: '/Mês',
    popular: false,
    features: [
      '4 aulas online de 1h/mês',
      'Horário flexível',
      'Aulas gravadas + materiais digitais',
      'Workshops online exclusivos',
    ],
  },
  {
    name: 'Músico',
    price: '140€',
    period: '/Mês',
    popular: false,
    features: [
      '8 aulas online de 1h/mês',
      'Horário flexível',
      'Aulas individuais + Cadeira Complementar',
      'Aulas gravadas',
      'Workshops online',
    ],
  },
  {
    name: 'Pack',
    price: '145€',
    period: '/4 Aulas',
    popular: false,
    features: [
      'Flexibilidade total',
      'Aulas gravadas',
      'Ideal para experimentar sem compromisso',
    ],
  },
];

const students = [
  {
    name: 'João Campello',
    image: '/fotos/joao-campello.png',
    quote: '"A academia transformou a minha relação com a música."',
  },
  {
    name: 'Manuel Dinis',
    image: '/fotos/manuel-dinis.png',
    quote: '"Subi ao palco pela primeira vez e foi inesquecível."',
  },
  {
    name: 'Francisca Borges',
    image: '/fotos/francisca-borges.png',
    quote: '"Os professores adaptaram-se completamente ao meu ritmo."',
  },
  {
    name: 'Miguel Dinis',
    image: '/fotos/miguel-dinis.jpg',
    quote: '"Das primeiras notas ao meu primeiro concerto em menos de um ano."',
  },
  {
    name: 'Hugo Bronze',
    image: '/fotos/hugo-bronze.png',
    quote: '"A melhor decisão que tomei foi entrar para a academia."',
  },
];

const sinergiaFeatures = [
  {
    title: 'COMUNIDADE BUNKER',
    description:
      'Ecossistema de músicos e artistas que podem aconselhar e ajudar os alunos da nossa academia.',
    image: '/fotos/comunidade-bunker.png',
  },
  {
    title: 'PRODUÇÃO AUDIOVISUAL',
    description:
      'Acesso a descontos na produção de áudio e vídeo com a nossa equipa audiovisual.',
    image: '/fotos/producao-audiovisual.jpg',
  },
  {
    title: 'OPORTUNIDADE DE PROFISSIONALIZAÇÃO',
    description:
      'Parcerias dinamizadoras que permitem ao aluno complementar o ensino com outras áreas igualmente importantes.',
    image: '/fotos/oportunidade-profissionalizacao.png',
  },
];
---

<BaseLayout
  title="Academia de Guitarra do Porto | Aprende Música em Porto"
  description="A Academia de Guitarra do Porto, powered by Bunker Records, oferece formação musical de qualidade em Porto. Do zero à tua primeira música em apenas 1 mês. Inscreve-te já!"
>
  <!-- ════════════ HERO ════════════ -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden" aria-label="Secção principal">
    <!-- Background image -->
    <div class="absolute inset-0 z-0" aria-hidden="true">
      <img
        src="/fotos/homepage/1.png"
        alt=""
        class="w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-hero-overlay"></div>
      <div class="absolute inset-0 bg-agp-bg/40"></div>
    </div>

    <!-- Red glow accent -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-96 h-64 bg-agp-red/10 blur-[80px] rounded-full pointer-events-none" aria-hidden="true"></div>

    <!-- Content -->
    <div class="relative z-10 container mx-auto px-4 md:px-8 text-center pt-32 pb-24">
      <p class="section-label text-center mb-4 fade-in-up">Porto, Portugal</p>

      <h1 class="font-heading text-6xl md:text-8xl lg:text-9xl text-white uppercase leading-none mb-6 fade-in-up [animation-delay:0.1s]" style="text-shadow: 0 2px 40px rgba(0,0,0,0.8);">
        APRENDE MÚSICA<br class="hidden md:block" />
        <span class="text-agp-red">DE FORMA PRÁTICA</span><br class="hidden md:block" />
        E AO TEU RITMO
      </h1>

      <div class="double-divider w-24 mx-auto fade-in-up [animation-delay:0.2s]">
        <span></span>
        <span></span>
      </div>

      <p class="font-heading text-xl md:text-2xl lg:text-3xl text-agp-muted tracking-widest uppercase mt-6 mb-10 fade-in-up [animation-delay:0.3s]">
        DO ZERO À TUA PRIMEIRA MÚSICA EM APENAS 1 MÊS.
      </p>

      <div class="fade-in-up [animation-delay:0.4s]">
        <a href="/contactos" class="btn-primary-lg" aria-label="Começa a aprender guitarra agora">
          COMEÇA AGORA!
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce" aria-hidden="true">
      <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- ════════════ O QUE NOS DIFERENCIA ════════════ -->
  <section class="py-24 bg-agp-bg" aria-labelledby="diferencia-title">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">

      <div class="text-center mb-16">
        <SectionDivider />
        <span class="section-label">O Que Nos Diferencia?</span>
        <h2 id="diferencia-title" class="section-title fade-in-up">O QUE NOS<br class="hidden md:block" /> DIFERENCIA?</h2>
        <SectionDivider />
        <p class="section-subtitle mt-6 max-w-3xl mx-auto fade-in-up">
          APOSTAMOS NUMA METODOLOGIA PRÓPRIA, PERFORMANCES CONSTANTES E PARCERIAS DINAMIZADORAS.
        </p>
      </div>

      <!-- 3 Feature cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">

        <!-- Card 1 -->
        <article class="relative overflow-hidden group cursor-pointer fade-in-up" aria-label="Metodologia Própria">
          <div class="aspect-[4/5] overflow-hidden">
            <img
              src="/fotos/metodologia-propria.jpg"
              alt="Professor ensinando guitarra a um aluno numa sala de aula"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
              decoding="async"
              width="800"
              height="1000"
            />
          </div>
          <!-- Default label -->
          <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-agp-bg/95 via-agp-bg/40 to-transparent transition-opacity duration-400 group-hover:opacity-0" aria-hidden="true">
            <h3 class="font-heading text-2xl text-white tracking-widest">METODOLOGIA PRÓPRIA</h3>
          </div>
          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-agp-bg/85 flex flex-col items-center justify-center p-8 text-center opacity-0 group-hover:opacity-100 transition-opacity duration-400">
            <h3 class="font-heading text-3xl text-white tracking-widest mb-4">METODOLOGIA PRÓPRIA</h3>
            <div class="double-divider w-16 mx-auto mb-4"><span></span><span></span></div>
            <p class="text-agp-muted leading-relaxed">Adaptamos os nossos métodos de ensino ao aluno, tendo em conta os seus objetivos.</p>
          </div>
        </article>

        <!-- Card 2 -->
        <article class="relative overflow-hidden group cursor-pointer fade-in-up" aria-label="Performance Constante">
          <div class="aspect-[4/5] overflow-hidden">
            <img
              src="/fotos/performance-constante.png"
              alt="Músico a tocar no palco com luzes de concerto"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
              decoding="async"
              width="800"
              height="1000"
            />
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-agp-bg/95 via-agp-bg/40 to-transparent transition-opacity duration-400 group-hover:opacity-0" aria-hidden="true">
            <h3 class="font-heading text-2xl text-white tracking-widest">PERFORMANCE CONSTANTE</h3>
          </div>
          <div class="absolute inset-0 bg-agp-bg/85 flex flex-col items-center justify-center p-8 text-center opacity-0 group-hover:opacity-100 transition-opacity duration-400">
            <h3 class="font-heading text-3xl text-white tracking-widest mb-4">PERFORMANCE CONSTANTE</h3>
            <div class="double-divider w-16 mx-auto mb-4"><span></span><span></span></div>
            <p class="text-agp-muted leading-relaxed">Apostamos em performances constantes para que o aluno possa evoluir mais rápido e para que possa tornar o palco o seu habitat.</p>
          </div>
        </article>

        <!-- Card 3 -->
        <article class="relative overflow-hidden group cursor-pointer fade-in-up" aria-label="Parcerias Dinamizadoras">
          <div class="aspect-[4/5] overflow-hidden">
            <img
              src="/fotos/parcerias-dinamizadoras.jpg"
              alt="Músicos em colaboração num concerto ao vivo"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
              decoding="async"
              width="800"
              height="1000"
            />
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-agp-bg/95 via-agp-bg/40 to-transparent transition-opacity duration-400 group-hover:opacity-0" aria-hidden="true">
            <h3 class="font-heading text-2xl text-white tracking-widest">PARCERIAS DINAMIZADORAS</h3>
          </div>
          <div class="absolute inset-0 bg-agp-bg/85 flex flex-col items-center justify-center p-8 text-center opacity-0 group-hover:opacity-100 transition-opacity duration-400">
            <h3 class="font-heading text-3xl text-white tracking-widest mb-4">PARCERIAS DINAMIZADORAS</h3>
            <div class="double-divider w-16 mx-auto mb-4"><span></span><span></span></div>
            <p class="text-agp-muted leading-relaxed">Parcerias dinamizadoras que permitem ao aluno complementar o ensino com outras áreas igualmente importantes.</p>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ════════════ PRICING ════════════ -->
  <section class="py-24 bg-[#080808]" aria-labelledby="pricing-title">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">

      <div class="text-center mb-16">
        <SectionDivider />
        <span class="section-label">Cursos</span>
        <h2 id="pricing-title" class="section-title fade-in-up">OS NOSSOS PLANOS</h2>
        <SectionDivider />
      </div>

      <div class="max-w-4xl mx-auto fade-in pt-6">
        <table class="w-full border-collapse" role="table" aria-label="Comparação de planos">
          <thead>
            <tr>
              <th class="w-[30%] pb-6" scope="col"></th>

              <!-- Básico -->
              <th class="w-[23%] text-center border border-white/10 border-r-agp-red bg-white/3 px-4 pt-8 pb-6" scope="col">
                <span class="font-heading text-xs tracking-[0.3em] text-agp-muted uppercase block mb-3">Plano</span>
                <span class="font-heading text-2xl text-white tracking-widest block">BÁSICO</span>
                <div class="double-divider w-8 mx-auto my-3"><span></span><span></span></div>
                <span class="font-heading text-4xl text-agp-red block">112€</span>
                <span class="text-agp-muted text-xs tracking-widest">/MÊS</span>
              </th>

              <!-- Músico (popular) -->
              <th class="w-[23%] text-center border border-agp-red bg-agp-red/10 px-4 pb-6 relative" scope="col">
                <div class="bg-agp-red py-2 px-4 -mx-px -mt-px mb-5 flex items-center justify-center gap-2">
                  <span class="text-yellow-400 text-xs">★</span>
                  <span class="font-heading text-white text-xs tracking-[0.2em]">MAIS POPULAR</span>
                </div>
                <span class="font-heading text-xs tracking-[0.3em] text-agp-muted uppercase block mb-3">Plano</span>
                <span class="font-heading text-2xl text-white tracking-widest block">MÚSICO</span>
                <div class="double-divider w-8 mx-auto my-3"><span></span><span></span></div>
                <span class="font-heading text-4xl text-agp-red block">140€</span>
                <span class="text-agp-muted text-xs tracking-widest">/MÊS</span>
              </th>

              <!-- Pack -->
              <th class="w-[23%] text-center border border-white/10 bg-white/3 px-4 pt-8 pb-6" scope="col">
                <span class="font-heading text-xs tracking-[0.3em] text-agp-muted uppercase block mb-3">Plano</span>
                <span class="font-heading text-2xl text-white tracking-widest block">PACK</span>
                <div class="double-divider w-8 mx-auto my-3"><span></span><span></span></div>
                <span class="font-heading text-4xl text-agp-red block">130€</span>
                <span class="text-agp-muted text-xs tracking-widest">/4 AULAS</span>
              </th>
            </tr>
          </thead>
          <tbody>
            {[
              { label: 'Modalidade',               basico: 'Presencial & Online', musico: 'Presencial & Online', pack: 'Presencial & Online' },
              { label: 'Aulas por mês',            basico: '4 aulas de 1h',       musico: '8 aulas de 1h',       pack: 'À vontade' },
              { label: 'Aulas individuais/mês',    basico: '4',                   musico: '4',                   pack: 'À vontade' },
              { label: 'Aulas em turma/mês',       basico: '—',                   musico: '4',                   pack: '—' },
              { label: 'Horário',                  basico: 'Fixo',                musico: 'Fixo',                pack: 'Flexível' },
              { label: 'Cadeira Complementar',      basico: '—',                   musico: '✓',                   pack: '—' },
              { label: 'Concertos & Jam Sessions',  basico: '✓',                   musico: '✓',                   pack: '✓' },
              { label: 'Comunidade',                basico: '✓',                   musico: '✓',                   pack: '✓' },
            ].map((row, i) => (
              <tr class={`border-b border-white/10 transition-colors duration-150 hover:bg-white/3 ${i % 2 === 0 ? 'bg-white/[0.02]' : ''}`}>
                <td class="py-4 px-2 text-agp-muted text-sm font-body tracking-wide">{row.label}</td>
                <td class={`py-4 px-4 text-center text-sm border-x border-white/10 border-r-agp-red ${row.basico === '✓' ? 'text-agp-red font-heading text-xl' : row.basico === '—' ? 'text-white/15 font-heading text-xl' : 'text-white font-body'}`}>{row.basico}</td>
                <td class={`py-4 px-4 text-center text-sm border border-agp-red bg-agp-red/5 ${row.musico === '✓' ? 'text-agp-red font-heading text-xl' : row.musico === '—' ? 'text-white/15 font-heading text-xl' : 'text-white font-body'}`}>{row.musico}</td>
                <td class={`py-4 px-4 text-center text-sm border-x border-white/10 ${row.pack === '✓' ? 'text-agp-red font-heading text-xl' : row.pack === '—' ? 'text-white/15 font-heading text-xl' : 'text-white font-body'}`}>{row.pack}</td>
              </tr>
            ))}
            <!-- CTA row -->
            <tr>
              <td class="pt-8 pb-2"></td>
              <td class="pt-8 pb-2 border-x border-white/10 border-r-agp-red text-center">
                <a href="/contactos" class="inline-block border border-white/30 text-white font-heading tracking-widest uppercase py-3 px-6 text-sm hover:border-agp-red hover:text-agp-red transition-colors duration-300">ESCOLHER</a>
              </td>
              <td class="pt-8 pb-2 border border-agp-red bg-agp-red/5 text-center">
                <a href="/contactos" class="inline-block bg-agp-red text-white font-heading tracking-widest uppercase py-3 px-6 text-sm hover:bg-agp-red-hover transition-colors duration-300">ESCOLHER</a>
              </td>
              <td class="pt-8 pb-2 border-x border-white/10 text-center">
                <a href="/contactos" class="inline-block border border-white/30 text-white font-heading tracking-widest uppercase py-3 px-6 text-sm hover:border-agp-red hover:text-agp-red transition-colors duration-300">ESCOLHER</a>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ════════════ DE ALUNOS A MÚSICOS ════════════ -->
  <section class="py-24 bg-[#080808] overflow-hidden" aria-labelledby="students-title">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">

      <div class="text-center mb-16">
        <SectionDivider />
        <span class="section-label">Os Nossos Alunos</span>
        <h2 id="students-title" class="section-title fade-in-up">DE ALUNOS A<br class="hidden md:block" /> MÚSICOS DE SUCESSO</h2>
        <SectionDivider />
        <p class="section-subtitle mt-6 fade-in-up">
          HISTÓRIAS REAIS DE QUEM JÁ TRANSFORMOU A SUA PAIXÃO EM ARTE.
        </p>
      </div>

      <!-- Horizontal Accordion -->
      <div
        class="h-accordion fade-in"
        id="student-accordion"
        role="list"
        aria-label="Histórias de alunos"
      >
        {students.map((student, i) => (
          <div
            class={`h-accordion-item ${i === 0 ? 'active' : ''}`}
            data-index={i}
            role="listitem"
            tabindex="0"
            aria-label={student.name}
          >
            <img
              src={student.image}
              alt={`${student.name}, aluno na Academia de Guitarra do Porto`}
              class="w-full h-full object-cover object-center"
              loading="lazy"
              decoding="async"
            />

            <!-- Detail (shown when active) -->
            <div class="item-detail">
              <p class="font-body text-agp-muted text-sm italic mb-3">{student.quote}</p>
              <h3 class="font-heading text-2xl text-white">{student.name}</h3>
            </div>

            <!-- Collapsed label -->
            <div class="item-label" aria-hidden="true">
              <span class="font-heading text-white text-sm tracking-widest">{student.name}</span>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ════════════ SINERGIA BUNKER ════════════ -->
  <section class="py-24 bg-agp-bg relative overflow-hidden" aria-labelledby="sinergia-title">
    <!-- Red glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-agp-red/5 blur-[100px] rounded-full pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 container mx-auto px-4 md:px-8 lg:px-12">

      <div class="text-center mb-16">
        <SectionDivider />
        <span class="section-label">Ecossistema</span>
        <h2 id="sinergia-title" class="section-title fade-in-up">SINERGIA BUNKER</h2>
        <SectionDivider />
        <p class="section-subtitle mt-6 max-w-3xl mx-auto fade-in-up">
          APOSTAMOS NUMA METODOLOGIA PRÓPRIA, PERFORMANCES CONSTANTES E PARCERIAS DINAMIZADORAS.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        {sinergiaFeatures.map((feature) => (
          <article class="fade-in-up group">
            <div class="aspect-[9/16] overflow-hidden mb-6">
              <img
                src={feature.image}
                alt={feature.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            </div>
            <h3 class="font-heading text-xl text-white tracking-widest mb-4">{feature.title}</h3>
            <div class="double-divider w-12 mb-4"><span></span><span></span></div>
            <p class="text-agp-muted leading-relaxed text-sm">{feature.description}</p>
          </article>
        ))}
      </div>

    </div>
  </section>

  <!-- ════════════ GOOGLE REVIEWS ════════════ -->
  <section class="py-24 bg-[#080808]" aria-labelledby="reviews-title">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">

      <!-- Header -->
      <div class="text-center mb-16">
        <SectionDivider />
        <span class="section-label">Google Reviews</span>
        <h2 id="reviews-title" class="section-title fade-in-up">O QUE DIZEM<br class="hidden md:block" /> OS NOSSOS ALUNOS</h2>
        <SectionDivider />

        <!-- Rating summary -->
        <div class="flex items-center justify-center gap-4 mt-8 fade-in-up">
          <span class="font-heading text-6xl text-white">4.9</span>
          <div class="flex flex-col items-start gap-1">
            <div class="flex items-center gap-0.5" aria-label="4.9 de 5 estrelas">
              {[1,2,3,4,5].map(() => (
                <svg class="w-6 h-6 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-agp-muted text-sm tracking-widest uppercase font-heading">50 reviews no Google</p>
          </div>
        </div>
      </div>

      <!-- Review cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">

        <article class="card-dark p-6 flex flex-col gap-4 fade-in-up">
          <div class="flex items-center gap-0.5" aria-label="5 estrelas">
            {[1,2,3,4,5].map(() => (
