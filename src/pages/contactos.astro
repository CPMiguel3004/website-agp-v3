---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionDivider from '../components/SectionDivider.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contactos | Academia de Guitarra do Porto"
  description="Contacta a Academia de Guitarra do Porto. Inscreve-te, pede mais informações ou agenda uma aula experimental. Estamos no Porto, Portugal."
>

  <!-- ════════════ HERO ════════════ -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center justify-center overflow-hidden" aria-label="Cabeçalho Contactos">
    <div class="absolute inset-0 z-0" aria-hidden="true">
      <img
        src="/fotos/homepage/8.png"
        alt=""
        class="w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-agp-bg/75"></div>
    </div>

    <div class="relative z-10 text-center px-4 pt-24">
      <span class="section-label text-center block">FALA CONNOSCO</span>
      <h1 class="font-heading text-7xl md:text-9xl text-white uppercase leading-none fade-in-up">
        CONTACTOS
      </h1>
    </div>
  </section>

  <!-- ════════════ CONTACT INFO STRIP ════════════ -->
  <section class="py-16 bg-[#080808]" aria-label="Informações de contacto">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">

        <!-- Email -->
        <article class="flex items-start gap-4 fade-in-up">
          <div class="w-12 h-12 bg-agp-red/10 border border-agp-red/30 flex items-center justify-center shrink-0" aria-hidden="true">
            <svg class="w-5 h-5 text-agp-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-lg text-white tracking-widest mb-1">EMAIL</h3>
            <a href="mailto:info@academiaguitarraporto.pt" class="text-agp-muted hover:text-agp-red transition-colors duration-200 text-sm break-all">
              info@academiaguitarraporto.pt
            </a>
          </div>
        </article>

        <!-- Telefone -->
        <article class="flex items-start gap-4 fade-in-up">
          <div class="w-12 h-12 bg-agp-red/10 border border-agp-red/30 flex items-center justify-center shrink-0" aria-hidden="true">
            <svg class="w-5 h-5 text-agp-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-lg text-white tracking-widest mb-1">TELEFONE</h3>
            <a href="tel:+351919127019" class="text-agp-muted hover:text-agp-red transition-colors duration-200 text-sm">
              +351 919 127 019
            </a>
          </div>
        </article>

        <!-- Morada -->
        <article class="flex items-start gap-4 fade-in-up">
          <div class="w-12 h-12 bg-agp-red/10 border border-agp-red/30 flex items-center justify-center shrink-0" aria-hidden="true">
            <svg class="w-5 h-5 text-agp-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-lg text-white tracking-widest mb-1">MORADA</h3>
            <address class="not-italic text-agp-muted text-sm">
              Rua Afonso Lopes Vieira 186<br />
              4100-020 Porto<br />
              Portugal
            </address>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ════════════ CONTACT FORM (prominent) ════════════ -->
  <ContactForm />

  <!-- ════════════ MAP ════════════ -->
  <section class="bg-agp-bg pb-24" aria-labelledby="map-title">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">

      <div class="text-center mb-12">
        <SectionDivider />
        <span class="section-label">Localização</span>
        <h2 id="map-title" class="section-title fade-in-up">ONDE NOS PODES<br class="hidden md:block" /> ENCONTRAR?</h2>
        <SectionDivider />
      </div>

      <!-- Map embed placeholder -->
      <div
        class="relative w-full h-80 md:h-[500px] border border-white/15 overflow-hidden fade-in"
        aria-label="Mapa de localização da Academia de Guitarra do Porto"
      >
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3004.1!2d-8.646709!3d41.163495!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd24659b051e9457%3A0x8d8e4c4361c0aa3e!2sAcademia%20de%20Guitarra%20do%20Porto%20-%20Powered%20by%20Bunker!5e0!3m2!1spt!2spt!4v1694000000000!5m2!1spt!2spt"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa com a localização da Academia de Guitarra do Porto"
        ></iframe>
      </div>

      <!-- Opening hours -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
        <div class="fade-in-up">
          <h3 class="font-heading text-2xl text-white mb-6 tracking-widest">HORÁRIO DE ATENDIMENTO</h3>
          <dl class="space-y-3">
            <div class="flex justify-between text-sm border-b border-white/10 pb-3">
              <dt class="text-agp-muted">Segunda — Sexta</dt>
              <dd class="text-white font-body">10:00 — 13:00 / 14:30 — 20:00</dd>
            </div>
            <div class="flex justify-between text-sm border-b border-white/10 pb-3">
              <dt class="text-agp-muted">Sábado</dt>
              <dd class="text-white font-body">09:00 — 14:00</dd>
            </div>
            <div class="flex justify-between text-sm">
              <dt class="text-agp-muted">Domingo</dt>
              <dd class="text-agp-red font-body">Fechado</dd>
            </div>
          </dl>
        </div>

        <div class="fade-in-up">
          <h3 class="font-heading text-2xl text-white mb-6 tracking-widest">REDES SOCIAIS</h3>
          <div class="flex flex-col gap-3">
            <a
              href="https://www.instagram.com/academiaguitarraporto/"
              class="flex items-center gap-3 text-agp-muted hover:text-white transition-colors duration-200 group"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Seguir no Instagram"
            >
              <span class="w-8 h-8 bg-white/5 flex items-center justify-center group-hover:bg-agp-red/20 transition-colors duration-200" aria-hidden="true">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </span>
              @academiadeguitarradoporto
            </a>
            <a
              href="https://www.facebook.com/academiaguitarraporto"
              class="flex items-center gap-3 text-agp-muted hover:text-white transition-colors duration-200 group"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Seguir no Facebook"
            >
              <span class="w-8 h-8 bg-white/5 flex items-center justify-center group-hover:bg-agp-red/20 transition-colors duration-200" aria-hidden="true">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </span>
              Academia de Guitarra do Porto
            </a>
            <a
              href="https://youtube.com/@academiadeguitarradoporto"
              class="flex items-center gap-3 text-agp-muted hover:text-white transition-colors duration-200 group"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Ver canal no YouTube"
            >
              <span class="w-8 h-8 bg-white/5 flex items-center justify-center group-hover:bg-agp-red/20 transition-colors duration-200" aria-hidden="true">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </span>
              @academiadeguitarradoporto
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
