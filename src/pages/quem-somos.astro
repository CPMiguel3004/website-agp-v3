---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionDivider from '../components/SectionDivider.astro';
import ContactForm from '../components/ContactForm.astro';

const valores = [
  {
    title: 'RESPEITO E INCLUSÃO',
    description:
      'Criamos um ambiente seguro, diverso e motivador, onde toda a gente se sente bem vinda.',
    image: '/fotos/bateria.png',
  },
  {
    title: 'COMPROMISSO COM A CULTURA',
    description:
      'Acreditamos no poder da arte para o bem-estar, a sociedade e o futuro. Queremos transmitir essa consciência a cada um dos nossos alunos.',
    image: '/fotos/compromisso-cultura.png',
  },
  {
    title: 'PARTILHA E COMUNIDADE',
    description:
      'A música é feita em conjunto. Cultivamos a ligação entre alunos, professores e o mundo exterior.',
    image: '/fotos/partilha-comunidade.jpg',
  },
];
---

<BaseLayout
  title="Quem Somos | Academia de Guitarra do Porto"
  description="Conheça a Academia de Guitarra do Porto, aliada à Bunker Records. Formação musical de qualidade com apoio ao desenvolvimento artístico e profissional em Porto."
>

  <!-- ════════════ HERO ════════════ -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center justify-center overflow-hidden" aria-label="Cabeçalho da página Quem Somos">
    <div class="absolute inset-0 z-0" aria-hidden="true">
      <img
        src="/fotos/homepage/12.png"
        alt=""
        class="w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-agp-bg/70"></div>
    </div>

    <div class="relative z-10 text-center px-4 pt-24">
      <span class="section-label text-center block">EMPRESA</span>
      <h1 class="font-heading text-7xl md:text-9xl text-white uppercase leading-none fade-in-up">
        QUEM SOMOS
      </h1>
    </div>
  </section>

  <!-- ════════════ MAIN TEXT ════════════ -->
  <section class="py-24 bg-agp-bg" aria-labelledby="about-title">
    <div class="container mx-auto px-4 md:px-8 lg:px-12 max-w-5xl">

      <div class="text-center mb-16">
        <SectionDivider />
        <span class="section-label">A Nossa História</span>
        <h2 id="about-title" class="section-title fade-in-up">A NOSSA ACADEMIA</h2>
        <SectionDivider />
      </div>

      <!-- Intro destaque -->
      <p class="font-heading text-2xl md:text-3xl text-white leading-snug tracking-wide text-center mb-12 fade-in-up">
        Na <span class="text-agp-red">Academia de Guitarra do Porto</span>, aliada à <span class="text-agp-red">BUNKER RECORDS</span>, acreditamos que a música transforma vidas — e acompanhamos cada aluno desde as primeiras notas até ao palco.
      </p>

      <!-- 2-col text body -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 fade-in-up">
        <div class="relative pl-6 border-l border-agp-red/50">
          <p class="text-agp-muted leading-loose text-base">
            Oferecemos formação em diversos instrumentos com uma metodologia própria, adaptada aos objetivos de cada aluno. Combinamos ensino individual com experiências de grupo para acelerar a evolução musical.
          </p>
        </div>
        <div class="relative pl-6 border-l border-agp-red/50">
          <p class="text-agp-muted leading-loose text-base">
            Ajudamos a transformar ideias musicais em projetos completos — da composição à produção, da gravação ao videoclip. Promovemos concertos ao vivo e apoiamos a divulgação junto de rádios e media.
          </p>
        </div>
      </div>

      <div class="text-center mt-12 fade-in-up">
        <a href="/contactos" class="btn-primary">JUNTA-TE A NÓS</a>
      </div>

    </div>
  </section>

  <!-- ════════════ QUOTE BANNER ════════════ -->
  <section class="relative py-20 overflow-hidden" aria-hidden="true">
    <div class="absolute inset-0 z-0">
      <img
        src="/fotos/img-1978.png"
        alt=""
        class="w-full h-full object-cover object-center"
        loading="lazy"
        decoding="async"
      />
      <div class="absolute inset-0 bg-agp-bg/82"></div>
    </div>
    <div class="relative z-10 container mx-auto px-4 text-center max-w-3xl">
      <div class="double-divider w-16 mx-auto mb-8"><span></span><span></span></div>
      <p class="font-heading text-3xl md:text-5xl text-white uppercase leading-tight fade-in-up" style="text-shadow: 0 2px 12px rgba(0,0,0,1), 0 0 40px rgba(0,0,0,0.9);">
        "A MÚSICA TRANSFORMA VIDAS. A TUA PODE SER A PRÓXIMA."
      </p>
      <div class="double-divider w-16 mx-auto mt-8"><span></span><span></span></div>
    </div>
  </section>

  <!-- ════════════ VALORES ════════════ -->
  <section class="py-24 bg-[#080808]" aria-labelledby="valores-title">
    <div class="container mx-auto px-4 md:px-8 lg:px-12 max-w-7xl">

      <div class="text-center mb-16">
        <SectionDivider />
        <span class="section-label">Os Nossos Valores</span>
        <h2 id="valores-title" class="section-title fade-in-up">OS NOSSOS VALORES</h2>
        <SectionDivider />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">
        {valores.map((valor) => (
          <article class="relative overflow-hidden group cursor-pointer fade-in-up" aria-label={valor.title}>
            <div class="aspect-[4/5] overflow-hidden">
              <img
                src={valor.image}
                alt={valor.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-black/95 via-black/40 to-transparent transition-opacity duration-400 group-hover:opacity-0" aria-hidden="true">
              <h3 class="font-heading text-2xl text-white tracking-widest">{valor.title}</h3>
            </div>
            <div class="absolute inset-0 bg-agp-bg/85 flex flex-col items-center justify-center p-8 text-center opacity-0 group-hover:opacity-100 transition-opacity duration-400">
              <h3 class="font-heading text-3xl text-white tracking-widest mb-4">{valor.title}</h3>
              <div class="double-divider w-16 mx-auto mb-4"><span></span><span></span></div>
              <p class="text-agp-muted leading-relaxed">{valor.description}</p>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>

  <!-- ════════════ CONTACT FORM ════════════ -->
  <ContactForm />

</BaseLayout>
